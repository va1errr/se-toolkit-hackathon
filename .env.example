# Database
# In Docker Compose, use the service name "postgres" on port 5432.
# When running outside Docker (bare metal), use localhost:5433 (the mapped port).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/labassist

# LLM (Qwen API via qwen-code-api proxy)
# When qwen-code-api is on the same Docker network, use its container name.
# Otherwise use your host IP (e.g. http://172.17.0.1:8080/v1).
LLM_API_BASE=http://qwen-code-api-qwen-code-api-1:8080/v1
LLM_API_KEY=your-api-key-here

# Auth
SECRET_KEY=change-this-to-a-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (comma-separated, no spaces)
CORS_ORIGINS=http://localhost

# App
APP_ENV=development
LOG_LEVEL=INFO
