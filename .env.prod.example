# Production environment variables
# Copy this to .env on your production server

# Database
POSTGRES_USER=labassist_user
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
POSTGRES_DB=labassist
DATABASE_URL=postgresql+asyncpg://labassist_user:CHANGE_ME_TO_STRONG_PASSWORD@postgres:5432/labassist

# LLM (via qwen-code-api proxy)
# NOTE: In Docker, localhost refers to the container itself, not the host.
# Use the qwen-code-api container name on a shared network, or the host IP.
# Example: LLM_API_BASE=http://qwen-code-api:8080/v1
LLM_API_BASE=http://localhost:8080/v1
LLM_API_KEY=anything

# Auth
SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_STRING_USE_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (your production domain)
CORS_ORIGINS=https://yourdomain.com

# App
APP_ENV=production
LOG_LEVEL=INFO
